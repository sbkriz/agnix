{
  "share": "manual",
  "instructions": ["**/*.md"],
  "model": "anthropic/claude-sonnet-4-5",
  "logLevel": "info",
  "autoupdate": true,
  "agent": {
    "my-agent": {
      "description": "A custom agent",
      "model": "openai/gpt-4o",
      "steps": 20,
      "temperature": 0.7,
      "top_p": 0.9,
      "color": "primary",
      "hidden": false
    }
  },
  "permission": {
    "read": "allow",
    "edit": "ask",
    "bash": "deny"
  },
  "compaction": {
    "reserved": 5
  },
  "skills": {
    "urls": ["https://example.com/skills"]
  },
  "mcp": {
    "my-server": {
      "type": "local",
      "command": ["node", "server.js"],
      "timeout": 5000
    }
  },
  "lsp": {
    "ts": {
      "command": "typescript-language-server",
      "extensions": [".ts", ".tsx"]
    }
  },
  "tui": {
    "theme": "dark",
    "scroll_speed": 1.0,
    "diff_style": "auto"
  }
}
